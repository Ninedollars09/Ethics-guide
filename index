<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ติวเข้ม พ.ร.บ.มาตรฐานทางจริยธรรม พ.ศ. 2562</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700;800;900&family=Sarabun:wght@300;400;500;600;700;800&family=Kanit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C8A65D;
  --gold-light: #E8D5A3;
  --gold-dark: #8B6914;
  --navy: #1B2A4A;
  --navy-deep: #0F1A30;
  --navy-light: #2A3F6A;
  --cream: #FDF8F0;
  --cream-dark: #F0E6D4;
  --red: #C4393B;
  --red-light: #E85D5F;
  --green: #2D8F5C;
  --green-light: #4DB87A;
  --text: #2C2C2C;
  --text-light: #666;
  --shadow-sm: 0 2px 8px rgba(27,42,74,0.08);
  --shadow-md: 0 4px 20px rgba(27,42,74,0.12);
  --shadow-lg: 0 8px 40px rgba(27,42,74,0.16);
  --radius: 16px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Sarabun', sans-serif;
  background: var(--cream);
  color: var(--text);
  line-height: 1.8;
  font-size: 17px;
  overflow-x: hidden;
}

/* === HERO SECTION === */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy) 40%, var(--navy-light) 100%);
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(200,166,93,0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(200,166,93,0.1) 0%, transparent 40%),
    radial-gradient(ellipse at 50% 80%, rgba(200,166,93,0.08) 0%, transparent 50%);
}

.hero-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 50px, rgba(255,255,255,0.5) 50px, rgba(255,255,255,0.5) 51px),
    repeating-linear-gradient(90deg, transparent, transparent 50px, rgba(255,255,255,0.5) 50px, rgba(255,255,255,0.5) 51px);
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 2rem;
  max-width: 800px;
  animation: heroFadeIn 1.2s ease-out;
}

@keyframes heroFadeIn {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero-badge {
  display: inline-block;
  padding: 8px 24px;
  background: rgba(200,166,93,0.15);
  border: 1px solid rgba(200,166,93,0.3);
  border-radius: 100px;
  color: var(--gold-light);
  font-size: 0.85rem;
  letter-spacing: 0;
  font-weight: 600;
  margin-bottom: 2rem;
  animation: heroFadeIn 1.2s ease-out 0.2s both;
}

.hero-title {
  font-family: 'Kanit', sans-serif;
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 0.5rem;
  animation: heroFadeIn 1.2s ease-out 0.4s both;
}

.hero-title .gold { color: var(--gold); }

.hero-subtitle {
  font-family: 'Kanit', sans-serif;
  font-size: clamp(1.2rem, 3vw, 1.8rem);
  color: rgba(255,255,255,0.7);
  font-weight: 300;
  margin-bottom: 2rem;
  animation: heroFadeIn 1.2s ease-out 0.6s both;
}

.hero-meta {
  display: flex;
  gap: 2rem;
  justify-content: center;
  flex-wrap: wrap;
  animation: heroFadeIn 1.2s ease-out 0.8s both;
}

.hero-meta-item {
  color: rgba(255,255,255,0.5);
  font-size: 0.9rem;
}

.hero-meta-item strong {
  color: var(--gold-light);
  display: block;
  font-size: 1.1rem;
}

.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  animation: bounce 2s infinite;
  color: rgba(255,255,255,0.3);
  font-size: 1.5rem;
  cursor: pointer;
  z-index: 2;
}

@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(10px); }
}

/* === NAVIGATION === */
.nav-sticky {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(27,42,74,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(200,166,93,0.2);
  padding: 0;
  overflow-x: auto;
}

.nav-inner {
  display: flex;
  max-width: 1200px;
  margin: 0 auto;
  gap: 0;
}

.nav-link {
  padding: 1rem 1.5rem;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 600;
  white-space: nowrap;
  transition: all 0.3s;
  border-bottom: 2px solid transparent;
  font-family: 'Kanit', sans-serif;
}

.nav-link:hover, .nav-link.active {
  color: var(--gold);
  border-bottom-color: var(--gold);
  background: rgba(200,166,93,0.05);
}

/* === MAIN CONTENT === */
.main {
  max-width: 900px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* === SECTION === */
.section {
  padding: 5rem 0 3rem;
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.section.visible {
  opacity: 1;
  transform: translateY(0);
}

.section-number {
  font-family: 'Kanit', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 0;
  margin-bottom: 0.5rem;
}

.section-title {
  font-family: 'Kanit', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  font-weight: 800;
  color: var(--navy);
  margin-bottom: 1.5rem;
  line-height: 1.3;
}

.section-lead {
  font-size: 1.15rem;
  color: var(--text-light);
  margin-bottom: 2rem;
  line-height: 2;
  max-width: 750px;
}

/* === CARDS === */
.card {
  background: #fff;
  border-radius: var(--radius);
  padding: 2rem;
  margin-bottom: 1.5rem;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(0,0,0,0.04);
  transition: all 0.3s;
}

.card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.card-navy {
  background: var(--navy);
  color: #fff;
}

.card-navy .card-title { color: var(--gold-light); }
.card-navy p { color: rgba(255,255,255,0.8); }

.card-gold {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
  color: #fff;
}

.card-title {
  font-family: 'Kanit', sans-serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 1rem;
}

.card-icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  margin-bottom: 1rem;
}

.icon-gold { background: rgba(200,166,93,0.15); }
.icon-red { background: rgba(196,57,59,0.1); }
.icon-green { background: rgba(45,143,92,0.1); }
.icon-navy { background: rgba(27,42,74,0.08); }

/* === 7 STANDARDS GRID === */
.standards-grid {
  display: grid;
  gap: 1rem;
  margin: 2rem 0;
}

.standard-item {
  display: flex;
  gap: 1.2rem;
  align-items: flex-start;
  background: #fff;
  padding: 1.5rem;
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  border-left: 4px solid var(--gold);
  transition: all 0.3s;
  cursor: pointer;
}

.standard-item:hover {
  box-shadow: var(--shadow-md);
  border-left-color: var(--navy);
  transform: translateX(4px);
}

.standard-item.expanded .standard-detail { display: block; }

.standard-num {
  width: 40px;
  height: 40px;
  min-width: 40px;
  border-radius: 50%;
  background: var(--navy);
  color: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Kanit', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
}

.standard-content { flex: 1; }

.standard-name {
  font-family: 'Kanit', sans-serif;
  font-weight: 600;
  font-size: 1.05rem;
  color: var(--navy);
  margin-bottom: 0.3rem;
}

.standard-short {
  color: var(--text-light);
  font-size: 0.9rem;
}

.standard-detail {
  display: none;
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px dashed rgba(0,0,0,0.1);
  color: var(--text);
  font-size: 0.95rem;
}

.standard-detail .example {
  background: rgba(45,143,92,0.06);
  border-left: 3px solid var(--green);
  padding: 0.8rem 1rem;
  margin: 0.5rem 0;
  border-radius: 0 8px 8px 0;
  font-size: 0.9rem;
}

.standard-detail .warning {
  background: rgba(196,57,59,0.06);
  border-left: 3px solid var(--red);
  padding: 0.8rem 1rem;
  margin: 0.5rem 0;
  border-radius: 0 8px 8px 0;
  font-size: 0.9rem;
}

/* === TABLES === */
.table-wrap {
  overflow-x: auto;
  margin: 1.5rem 0;
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
}

table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
  font-size: 0.95rem;
}

thead th {
  background: var(--navy);
  color: var(--gold-light);
  padding: 1rem 1.2rem;
  text-align: left;
  font-family: 'Kanit', sans-serif;
  font-weight: 600;
  font-size: 0.9rem;
}

tbody td {
  padding: 0.9rem 1.2rem;
  border-bottom: 1px solid rgba(0,0,0,0.05);
  vertical-align: top;
}

tbody tr:hover { background: rgba(200,166,93,0.04); }

tbody tr:last-child td { border-bottom: none; }

.tag {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 100px;
  font-size: 0.8rem;
  font-weight: 600;
}

.tag-yes { background: rgba(45,143,92,0.1); color: var(--green); }
.tag-no { background: rgba(196,57,59,0.1); color: var(--red); }

/* === PITFALL CARDS === */
.pitfall {
  background: #fff;
  border-radius: var(--radius);
  padding: 2rem;
  margin-bottom: 1.5rem;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(196,57,59,0.1);
  position: relative;
  overflow: hidden;
}

.pitfall::before {
  content: '⚠';
  position: absolute;
  top: -10px;
  right: -5px;
  font-size: 5rem;
  opacity: 0.05;
}

.pitfall-num {
  display: inline-block;
  background: var(--red);
  color: #fff;
  font-family: 'Kanit', sans-serif;
  font-weight: 800;
  font-size: 0.8rem;
  padding: 3px 12px;
  border-radius: 100px;
  margin-bottom: 0.8rem;
}

.pitfall-title {
  font-family: 'Kanit', sans-serif;
  font-weight: 700;
  font-size: 1.15rem;
  color: var(--red);
  margin-bottom: 0.8rem;
}

.pitfall-tip {
  background: rgba(45,143,92,0.06);
  border-radius: 10px;
  padding: 1rem 1.2rem;
  margin-top: 1rem;
  font-size: 0.9rem;
}

.pitfall-tip strong {
  color: var(--green);
  font-family: 'Kanit', sans-serif;
}

/* === MNEMONIC === */
.mnemonic {
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
  border-radius: var(--radius);
  padding: 2.5rem;
  margin: 2rem 0;
  text-align: center;
  color: #fff;
}

.mnemonic-label {
  font-size: 0.8rem;
  letter-spacing: 0;
  color: var(--gold);
  margin-bottom: 1rem;
  font-weight: 700;
}

.mnemonic-text {
  font-family: 'Kanit', sans-serif;
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 800;
  line-height: 1.5;
}

.mnemonic-text .highlight {
  color: var(--gold);
  text-decoration: underline;
  text-decoration-color: rgba(200,166,93,0.3);
  text-underline-offset: 4px;
}

/* === NUMBERS SECTION === */
.numbers-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
  gap: 1rem;
  margin: 2rem 0;
}

.number-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 1.5rem;
  box-shadow: var(--shadow-sm);
  text-align: center;
  transition: all 0.3s;
}

.number-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-3px);
}

.number-value {
  font-family: 'Kanit', sans-serif;
  font-size: 2.5rem;
  font-weight: 900;
  color: var(--navy);
  line-height: 1;
}

.number-label {
  font-size: 0.85rem;
  color: var(--text-light);
  margin-top: 0.3rem;
}

.number-reason {
  font-size: 0.8rem;
  color: var(--gold-dark);
  background: rgba(200,166,93,0.1);
  padding: 6px 12px;
  border-radius: 8px;
  margin-top: 0.8rem;
  display: inline-block;
}

/* === STRUCTURE DIAGRAM === */
.structure-box {
  background: #fff;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  margin: 2rem 0;
}

.structure-header {
  background: var(--navy);
  padding: 1.5rem 2rem;
  text-align: center;
}

.structure-header h3 {
  font-family: 'Kanit', sans-serif;
  color: var(--gold);
  font-size: 1.3rem;
}

.structure-header p {
  color: rgba(255,255,255,0.6);
  font-size: 0.9rem;
}

.structure-body { padding: 2rem; }

.structure-row {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  margin-bottom: 0.5rem;
  border-radius: 10px;
  transition: background 0.2s;
}

.structure-row:hover { background: rgba(200,166,93,0.06); }

.structure-role {
  min-width: 140px;
  font-family: 'Kanit', sans-serif;
  font-weight: 600;
  color: var(--navy);
  font-size: 0.9rem;
}

.structure-who {
  flex: 1;
  font-size: 0.95rem;
}

.structure-count {
  background: var(--navy);
  color: var(--gold);
  font-family: 'Kanit', sans-serif;
  font-weight: 800;
  font-size: 0.8rem;
  padding: 4px 14px;
  border-radius: 100px;
  white-space: nowrap;
}

/* === QUIZ BUTTON === */
.quiz-toggle {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--gold);
  color: #fff;
  border: none;
  padding: 12px 24px;
  border-radius: 100px;
  font-family: 'Kanit', sans-serif;
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s;
  margin: 1rem 0;
}

.quiz-toggle:hover {
  background: var(--gold-dark);
  transform: scale(1.03);
}

/* === FOOTER === */
.footer {
  background: var(--navy-deep);
  color: rgba(255,255,255,0.4);
  text-align: center;
  padding: 3rem 1.5rem;
  margin-top: 4rem;
  font-size: 0.85rem;
}

.footer strong { color: var(--gold); }

/* === DIVIDER === */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(200,166,93,0.3), transparent);
  margin: 3rem 0;
}

/* === RESPONSIVE === */
@media (max-width: 768px) {
  .hero-meta { gap: 1rem; }
  .nav-link { padding: 0.8rem 1rem; font-size: 0.8rem; }
  .card { padding: 1.5rem; }
  .structure-row { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  .structure-role { min-width: auto; }
  .numbers-grid { grid-template-columns: repeat(2, 1fr); }
}

/* === CLICK EXPAND INDICATOR === */
.expand-hint {
  font-size: 0.75rem;
  color: var(--gold);
  font-weight: 600;
  margin-top: 0.3rem;
}

/* === FLOWCHART === */
.flow {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  margin: 2rem 0;
}

.flow-item {
  background: #fff;
  border: 2px solid var(--gold);
  border-radius: 12px;
  padding: 1rem 2rem;
  text-align: center;
  font-family: 'Kanit', sans-serif;
  font-weight: 600;
  max-width: 400px;
  width: 100%;
}

.flow-arrow {
  color: var(--gold);
  font-size: 1.5rem;
  line-height: 1;
  padding: 0.3rem 0;
}

.flow-item.highlight-flow {
  background: var(--navy);
  color: var(--gold);
  border-color: var(--navy);
}
</style>
</head>
